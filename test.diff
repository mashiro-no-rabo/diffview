diff --git a/next/lib/custom-reports/assemble.ts b/next/lib/custom-reports/assemble.ts
new file mode 100644
index 0000000000..5f81b0f59d
--- /dev/null
+++ b/next/lib/custom-reports/assemble.ts
@@ -0,0 +1,89 @@
+import { evaluateExpression } from "./expression";
+import { CustomReportDefinition } from "./types";
+
+const COMPOSITE_KEY_SEPARATOR = "\x00";
+
+function buildKeyString(row: Record<string, any>, keys: string | string[]): string {
+  const keyArray = Array.isArray(keys) ? keys : [keys];
+  return keyArray.map((k) => String(row[k] ?? "")).join(COMPOSITE_KEY_SEPARATOR);
+}
+
+function getRowId(row: Record<string, any>): string {
+  return String(row.id ?? "");
+}
+
+export function assembleCustomReport(
+  definition: CustomReportDefinition,
+  worksheetData: Record<string, any[]>,
+): Record<string, any>[] {
+  let rows = (worksheetData[definition.primary_worksheet_id] ?? []).map((row) => ({
+    ...row,
+    _cr_id: getRowId(row),
+  }));
+
+  for (const join of definition.joins) {
+    const rightRows = worksheetData[join.right_worksheet_id] ?? [];
+    const lookup = new Map<string, Record<string, any>[]>();
+    for (const rightRow of rightRows) {
+      const key = buildKeyString(rightRow, join.right_key);
+      const existing = lookup.get(key);
+      if (existing) {
+        existing.push(rightRow);
+      } else {
+        lookup.set(key, [rightRow]);
+      }
+    }
+
+    rows = rows.flatMap((row) => {
+      const key = buildKeyString(row, join.left_key);
+      const matches = lookup.get(key);
+
+      if (matches && matches.length > 0) {
+        return matches.map((match) => ({
+          ...row,
+          ...match,
+          _cr_id: `${row._cr_id}|${getRowId(match)}`,
+        }));
+      }
+
+      if (join.join_type === "left") {
+        return [row];
+      }
+
+      return [];
+    });
+  }
+
+  return rows.map((row) => {
+    const result: Record<string, any> = { id: row._cr_id };
+
+    for (const col of definition.columns) {
+      if (col.source && col.time_series_format != null) {
+        // Keep timeseries dict as-is — AG Grid resolves "col.dateKey" via dot-path access
+        const tsValue = row[col.source.column_id];
+        result[col.id] = tsValue && typeof tsValue === "object" && !Array.isArray(tsValue) ? tsValue : null;
+      } else if (col.source) {
+        result[col.id] = row[col.source.column_id] ?? null;
+      } else if (col.computed) {
+        const numericValues: Record<string, number | null> = {};
+        for (const otherCol of definition.columns) {
+          if (otherCol.source && result[otherCol.id] !== undefined) {
+            const val = result[otherCol.id];
+            numericValues[otherCol.id] = typeof val === "number" ? val : null;
+          }
+        }
+        for (const otherCol of definition.columns) {
+          if (otherCol.source) {
+            const val = row[otherCol.source.column_id];
+            numericValues[otherCol.source.column_id] = typeof val === "number" ? val : null;
+          }
+        }
+        result[col.id] = evaluateExpression(col.computed.expression, numericValues);
+      } else {
+        result[col.id] = row[col.id] ?? null;
+      }
+    }
+
+    return result;
+  });
+}
diff --git a/next/lib/custom-reports/columns.ts b/next/lib/custom-reports/columns.ts
new file mode 100644
index 0000000000..1c7e6fbe60
--- /dev/null
+++ b/next/lib/custom-reports/columns.ts
@@ -0,0 +1,148 @@
+import { ColDef, ValueFormatterParams } from "ag-grid-community";
+
+import { ReportColumnDefinition } from "./types";
+
+function mapCellDataType(dataType: string): string {
+  switch (dataType) {
+    case "INTEGER":
+    case "DECIMAL":
+      return "number";
+    case "BOOLEAN":
+      return "boolean";
+    case "DATE":
+      return "dateString";
+    default:
+      return "text";
+  }
+}
+
+function mapWidth(width?: string): number | undefined {
+  switch (width) {
+    case "SMALL":
+      return 100;
+    case "MEDIUM":
+      return 150;
+    case "LARGE":
+      return 250;
+    default:
+      return undefined;
+  }
+}
+
+/**
+ * Build AG Grid column defs from report column definitions.
+ * For TIMESERIES columns, we need the actual row data to discover the date keys
+ * and expand them into individual columns.
+ */
+export function buildColumnDefs(
+  columns: ReportColumnDefinition[],
+  rowData?: Record<string, any>[],
+  defaultGrouping?: string[],
+): ColDef[] {
+  const defs: ColDef[] = [];
+  const groupOrder = new Map((defaultGrouping ?? []).map((id, idx) => [id, idx]));
+
+  for (const col of columns) {
+    const isTimeSeries = col.time_series_format != null;
+    if (isTimeSeries && rowData && rowData.length > 0) {
+      // Find the first row that has this timeseries column with data
+      const sampleRow = rowData.find((r) => r[col.id] && typeof r[col.id] === "object");
+      if (sampleRow) {
+        const tsData = sampleRow[col.id] as Record<string, any>;
+        const dateKeys = Object.keys(tsData).sort();
+        for (const dateKey of dateKeys) {
+          const fieldId = `${col.id}.${dateKey}`;
+          defs.push({
+            field: fieldId,
+            headerName: formatDateHeader(dateKey, col.time_series_format),
+            headerTooltip: col.description,
+            editable: false,
+            cellDataType: "number",
+            aggFunc: col.aggregator?.toLowerCase(),
+            minWidth: 100,
+            filter: false,
+            valueFormatter: (params: ValueFormatterParams) => {
+              if (params.value == null) return "";
+              const val = typeof params.value === "number" ? params.value : Number(params.value);
+              if (isNaN(val)) return "";
+              return col.postfix ? `${val}${col.postfix}` : String(val);
+            },
+          });
+        }
+      }
+    } else if (isTimeSeries) {
+      // No row data yet — add a placeholder column
+      defs.push({
+        field: col.id,
+        headerName: col.title,
+        headerTooltip: col.description,
+        editable: false,
+        hide: true,
+      });
+    } else {
+      const isGrouped = groupOrder.has(col.id);
+      const colDef: ColDef = {
+        field: col.id,
+        headerName: col.title,
+        headerTooltip: col.description,
+        editable: false,
+        hide: isGrouped || col.default_visible === false,
+        cellDataType: mapCellDataType(col.data_type),
+        rowGroup: isGrouped || undefined,
+        rowGroupIndex: isGrouped ? groupOrder.get(col.id) : undefined,
+      };
+
+      if (col.aggregator) {
+        colDef.aggFunc = col.aggregator.toLowerCase();
+      }
+
+      const width = mapWidth(col.width);
+      if (width) {
+        colDef.minWidth = width;
+      }
+
+      if (col.postfix) {
+        const postfix = col.postfix;
+        colDef.valueFormatter = (params: ValueFormatterParams) => {
+          if (params.value == null) return "";
+          return `${params.value}${postfix}`;
+        };
+      }
+
+      if (col.default_ui_filterable !== false) {
+        colDef.filter = true;
+      }
+
+      defs.push(colDef);
+    }
+  }
+
+  return defs;
+}
+
+function formatDateHeader(dateKey: string, timeSeriesFormat?: string | null): string {
+  try {
+    const date = new Date(dateKey);
+    if (isNaN(date.getTime())) return dateKey;
+
+    switch (timeSeriesFormat) {
+      case "MONTHLY":
+        return date.toLocaleDateString(undefined, { year: "numeric", month: "short" });
+      case "WEEKLY":
+        return `W${getWeekNumber(date)} ${date.getFullYear()}`;
+      case "DAILY":
+        return date.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
+      default:
+        return date.toLocaleDateString(undefined, { year: "numeric", month: "short" });
+    }
+  } catch {
+    return dateKey;
+  }
+}
+
+function getWeekNumber(date: Date): number {
+  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
+  d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay() || 7));
+  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
+  return Math.ceil(((d.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);
+}
diff --git a/next/lib/custom-reports/expression.ts b/next/lib/custom-reports/expression.ts
new file mode 100644
index 0000000000..1da37b5944
--- /dev/null
+++ b/next/lib/custom-reports/expression.ts
@@ -0,0 +1,205 @@
+type Token =
+  | { type: "number"; value: number }
+  | { type: "ident"; value: string }
+  | { type: "op"; value: string }
+  | { type: "lparen" }
+  | { type: "rparen" };
+
+function tokenize(expression: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < expression.length) {
+    const ch = expression[i];
+
+    if (ch === " " || ch === "\t") {
+      i++;
+      continue;
+    }
+
+    if (ch === "(") {
+      tokens.push({ type: "lparen" });
+      i++;
+      continue;
+    }
+
+    if (ch === ")") {
+      tokens.push({ type: "rparen" });
+      i++;
+      continue;
+    }
+
+    if (ch === "+" || ch === "-" || ch === "*" || ch === "/") {
+      tokens.push({ type: "op", value: ch });
+      i++;
+      continue;
+    }
+
+    if (ch >= "0" && ch <= "9" || ch === ".") {
+      let num = "";
+      while (i < expression.length && (expression[i] >= "0" && expression[i] <= "9" || expression[i] === ".")) {
+        num += expression[i];
+        i++;
+      }
+      tokens.push({ type: "number", value: parseFloat(num) });
+      continue;
+    }
+
+    if ((ch >= "a" && ch <= "z") || (ch >= "A" && ch <= "Z") || ch === "_") {
+      let ident = "";
+      while (
+        i < expression.length &&
+        ((expression[i] >= "a" && expression[i] <= "z") ||
+          (expression[i] >= "A" && expression[i] <= "Z") ||
+          (expression[i] >= "0" && expression[i] <= "9") ||
+          expression[i] === "_")
+      ) {
+        ident += expression[i];
+        i++;
+      }
+      tokens.push({ type: "ident", value: ident });
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${ch}`);
+  }
+
+  return tokens;
+}
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token | undefined {
+    return this.tokens[this.pos];
+  }
+
+  private consume(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  parseExpression(): (values: Record<string, number | null>) => number | null {
+    return this.parseAddSub();
+  }
+
+  private isOp(chars: string[]): boolean {
+    const t = this.peek();
+    return t !== undefined && t.type === "op" && chars.includes(t.value);
+  }
+
+  private parseAddSub(): (values: Record<string, number | null>) => number | null {
+    let left = this.parseMulDiv();
+
+    while (this.isOp(["+", "-"])) {
+      const op = (this.consume() as { type: "op"; value: string }).value;
+      const right = this.parseMulDiv();
+      const prevLeft = left;
+      if (op === "+") {
+        left = (v) => {
+          const l = prevLeft(v);
+          const r = right(v);
+          if (l === null || r === null) return null;
+          return l + r;
+        };
+      } else {
+        left = (v) => {
+          const l = prevLeft(v);
+          const r = right(v);
+          if (l === null || r === null) return null;
+          return l - r;
+        };
+      }
+    }
+
+    return left;
+  }
+
+  private parseMulDiv(): (values: Record<string, number | null>) => number | null {
+    let left = this.parseAtom();
+
+    while (this.isOp(["*", "/"])) {
+      const op = (this.consume() as { type: "op"; value: string }).value;
+      const right = this.parseAtom();
+      const prevLeft = left;
+      if (op === "*") {
+        left = (v) => {
+          const l = prevLeft(v);
+          const r = right(v);
+          if (l === null || r === null) return null;
+          return l * r;
+        };
+      } else {
+        left = (v) => {
+          const l = prevLeft(v);
+          const r = right(v);
+          if (l === null || r === null) return null;
+          if (r === 0) return null;
+          return l / r;
+        };
+      }
+    }
+
+    return left;
+  }
+
+  private parseAtom(): (values: Record<string, number | null>) => number | null {
+    const token = this.peek();
+
+    if (!token) {
+      throw new Error("Unexpected end of expression");
+    }
+
+    if (token.type === "number") {
+      this.consume();
+      const val = token.value;
+      return () => val;
+    }
+
+    if (token.type === "ident") {
+      this.consume();
+      const name = token.value;
+      return (v) => {
+        if (!(name in v)) return null;
+        return v[name];
+      };
+    }
+
+    if (token.type === "lparen") {
+      this.consume();
+      const expr = this.parseExpression();
+      const closing = this.consume();
+      if (!closing || closing.type !== "rparen") {
+        throw new Error("Expected closing parenthesis");
+      }
+      return expr;
+    }
+
+    if (token.type === "op" && token.value === "-") {
+      this.consume();
+      const operand = this.parseAtom();
+      return (v) => {
+        const val = operand(v);
+        if (val === null) return null;
+        return -val;
+      };
+    }
+
+    throw new Error(`Unexpected token: ${JSON.stringify(token)}`);
+  }
+}
+
+export function evaluateExpression(
+  expression: string,
+  values: Record<string, number | null>,
+): number | null {
+  const tokens = tokenize(expression);
+  const parser = new Parser(tokens);
+  const evaluate = parser.parseExpression();
+  return evaluate(values);
+}
diff --git a/next/lib/custom-reports/to-worksheet.ts b/next/lib/custom-reports/to-worksheet.ts
new file mode 100644
index 0000000000..77c58e0046
--- /dev/null
+++ b/next/lib/custom-reports/to-worksheet.ts
@@ -0,0 +1,91 @@
+import {
+  AccessLevelEnum,
+  ColumnDataTypeEnum,
+  ColumnWidthEnum,
+  NewWorksheet,
+  NewWorksheetColumn,
+  TimeSeriesFormatEnum,
+} from "@plaio/shared-types";
+
+import { CustomReportDefinition, ReportColumnDefinition } from "./types";
+
+function mapDataType(dt: string): ColumnDataTypeEnum {
+  switch (dt) {
+    case "INTEGER":
+      return ColumnDataTypeEnum.Integer;
+    case "DECIMAL":
+      return ColumnDataTypeEnum.Decimal;
+    case "BOOLEAN":
+      return ColumnDataTypeEnum.Boolean;
+    case "DATE":
+      return ColumnDataTypeEnum.Date;
+    case "DATETIME":
+      return ColumnDataTypeEnum.DateTime;
+    case "STRING":
+      return ColumnDataTypeEnum.String;
+    default:
+      return ColumnDataTypeEnum.String;
+  }
+}
+
+function mapWidth(w?: string): ColumnWidthEnum {
+  switch (w) {
+    case "SMALL":
+      return ColumnWidthEnum.Small;
+    case "LARGE":
+      return ColumnWidthEnum.Large;
+    default:
+      return ColumnWidthEnum.Medium;
+  }
+}
+
+function mapTimeSeriesFormat(f?: string | null): TimeSeriesFormatEnum | null {
+  if (!f) return null;
+  return f as TimeSeriesFormatEnum;
+}
+
+function toWorksheetColumn(col: ReportColumnDefinition, groupIndex: number | null): NewWorksheetColumn {
+  return {
+    aggregator: (col.aggregator as any) ?? null,
+    data_type: mapDataType(col.data_type),
+    description: col.description ?? "",
+    group_order: groupIndex,
+    id: col.id,
+    is_dropdown: false,
+    is_editable: false,
+    is_ui_filter_dropdown: col.is_ui_filter_dropdown ?? false,
+    is_ui_filterable: col.default_ui_filterable ?? false,
+    is_visible: col.default_visible !== false,
+    num_digits: null,
+    postfix: col.postfix ?? null,
+    postfix_from_column: null,
+    postfix_separator: null,
+    prefix: null,
+    prefix_from_column: null,
+    prefix_separator: null,
+    styles: [],
+    title: col.title,
+    time_series_format: mapTimeSeriesFormat(col.time_series_format),
+    width: mapWidth(col.width),
+  };
+}
+
+export function toWorksheetStructure(reportId: string, title: string, definition: CustomReportDefinition): NewWorksheet {
+  const groupOrder = new Map((definition.default_grouping ?? []).map((id, idx) => [id, idx]));
+
+  return {
+    access_level: AccessLevelEnum.View,
+    actions: [],
+    columns: definition.columns.map((col) => toWorksheetColumn(col, groupOrder.get(col.id) ?? null)),
+    description: definition.description,
+    id: reportId,
+    required_selectors: [],
+    row_tabs: [],
+    title,
+    ui_configuration: {
+      full_worksheet_target_id: null,
+      group_suppress_count: false,
+      tree_data: null,
+    },
+  };
+}
diff --git a/next/lib/custom-reports/types.ts b/next/lib/custom-reports/types.ts
new file mode 100644
