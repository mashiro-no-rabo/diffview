@@ -0,0 +1,50 @@
+export interface ColumnSource {
+  worksheet_id: string;
+  column_id: string;
+}
+
+export interface ComputedExpression {
+  expression: string;
+}
+
+export interface ReportColumnDefinition {
+  id: string;
+  title: string;
+  description?: string;
+  source?: ColumnSource;
+  computed?: ComputedExpression;
+  data_type: string;
+  aggregator?: string | null;
+  width?: string;
+  postfix?: string | null;
+  default_visible?: boolean;
+  default_ui_filterable?: boolean;
+  is_ui_filter_dropdown?: boolean;
+  time_series_format?: string | null;
+}
+
+export interface JoinSpec {
+  left_worksheet_id: string;
+  right_worksheet_id: string;
+  left_key: string | string[];
+  right_key: string | string[];
+  join_type: "inner" | "left";
+}
+
+export interface CustomReportDefinition {
+  description: string;
+  primary_worksheet_id: string;
+  columns: ReportColumnDefinition[];
+  joins: JoinSpec[];
+  default_grouping?: string[];
+}
+
+export interface CustomReport {
+  id: string;
+  report_id: string;
+  title: string;
+  user_prompt: string;
+  definition: CustomReportDefinition;
+  created_at: string;
+  updated_at: string;
+}
