@@ -0,0 +1,73 @@
+from sqlalchemy import delete, select
+from sqlalchemy.ext.asyncio import AsyncSession
+
+from app.custom_reports.agent import generation_agent
+from app.custom_reports.models import CustomReportDB
+from app.custom_reports.schemas import CustomReportDefinition
+from app.helpers.query import query_into_list, query_one_or_404
+
+
+async def generate_report(prompt: str) -> CustomReportDefinition:
+    result = await generation_agent.run(prompt)
+    return result.output
+
+
+async def update_report(
+    db_session: AsyncSession,
+    report_id: str,
+    prompt: str,
+    current_definition: CustomReportDefinition,
+) -> CustomReportDefinition:
+    update_prompt = (
+        f"Current report definition:\n{current_definition.model_dump_json(indent=2)}\n\n"
+        f"User request: {prompt}\n\n"
+        "Update the report definition based on the user's request. "
+        "Keep existing columns/joins unless the user asks to change them."
+    )
+    result = await generation_agent.run(update_prompt)
+    new_definition = result.output
+
+    # Persist the updated definition
+    report = await query_one_or_404(
+        db_session,
+        select(CustomReportDB).where(CustomReportDB.report_id == report_id),
+        msg=f"Report '{report_id}' not found",
+    )
+    report.definition = new_definition
+    await db_session.commit()
+
+    return new_definition
+
+
+async def create_report(
+    db_session: AsyncSession,
+    report_id: str,
+    title: str,
+    user_prompt: str,
+    definition: CustomReportDefinition,
+) -> CustomReportDB:
+    report = CustomReportDB(
+        report_id=report_id,
+        title=title,
+        user_prompt=user_prompt,
+        definition=definition,
+    )
+    await report.persist_and_commit(db_session)
+    return report
+
+
+async def list_reports(db_session: AsyncSession) -> list[CustomReportDB]:
+    return await query_into_list(db_session, select(CustomReportDB).order_by(CustomReportDB.created_at.desc()))
+
+
+async def get_report(db_session: AsyncSession, report_id: str) -> CustomReportDB:
+    return await query_one_or_404(
+        db_session,
+        select(CustomReportDB).where(CustomReportDB.report_id == report_id),
+        msg=f"Report '{report_id}' not found",
+    )
+
+
+async def delete_report(db_session: AsyncSession, report_id: str) -> None:
+    await db_session.execute(delete(CustomReportDB).where(CustomReportDB.report_id == report_id))
+    await db_session.commit()
