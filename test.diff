+from sqlalchemy import Unicode
+from sqlalchemy.orm import Mapped, mapped_column
+
+from app.core.base_db import BaseDB, DateAtMixin
+from app.core.extensions.sqlalchemy_ext import SATypePydantic
+from app.custom_reports.schemas import CustomReportDefinition
+
+
+class CustomReportDB(BaseDB, DateAtMixin, kw_only=True):
+    __tablename__ = "custom_reports"
+    __table_args__ = {"schema": "plaio_dbo"}
+
+    id: Mapped[int] = mapped_column(init=False, primary_key=True)
+    report_id: Mapped[str] = mapped_column(Unicode(256), unique=True)
+    title: Mapped[str] = mapped_column(Unicode(512))
