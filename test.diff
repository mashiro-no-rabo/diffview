--- /dev/null
+++ b/next/components/custom-reports/report-builder.tsx
@@ -0,0 +1,349 @@
+import { AutoAwesomeOutlined, SaveOutlined, SendOutlined } from "@mui/icons-material";
+import {
+  Button,
+  Dialog,
+  DialogActions,
+  DialogContent,
+  DialogTitle,
+  IconButton,
+  TextField,
+  Tooltip,
+} from "@mui/material";
+import i18next from "i18next";
+import { useRouter } from "next/router";
+import { type JSX, useCallback, useEffect, useMemo, useRef, useState } from "react";
+import { useTranslation } from "react-i18next";
+
+import { LoaderCircle, PageHeader } from "@plaio/components/ui";
+import { post, useLayoutStore, useOrgMembershipByPathParam } from "@plaio/data-access";
+
+import { assembleCustomReport } from "../../lib/custom-reports/assemble";
+import { buildColumnDefs } from "../../lib/custom-reports/columns";
+import { CustomReportDefinition } from "../../lib/custom-reports/types";
+import { ReportGrid } from "./report-grid";
+
+interface ChatMessage {
+  role: "user" | "assistant";
+  content: string;
+  definition?: CustomReportDefinition;
+}
+
+export function ReportBuilder(): JSX.Element {
+  const { t } = useTranslation();
+  const router = useRouter();
+  const orgMembership = useOrgMembershipByPathParam();
+  const raiseError = useLayoutStore((state) => state.raiseError);
+  const setMainMenu = useLayoutStore((state) => state.setMainMenu);
+
+  const [messages, setMessages] = useState<ChatMessage[]>([]);
+  const [input, setInput] = useState("");
+  const [isGenerating, setIsGenerating] = useState(false);
+  const [isSaving, setIsSaving] = useState(false);
+  const [definition, setDefinition] = useState<CustomReportDefinition | null>(null);
+  const [showSaveDialog, setShowSaveDialog] = useState(false);
+  const [reportId, setReportId] = useState("");
+  const [reportTitle, setReportTitle] = useState("");
+  const [idManuallyEdited, setIdManuallyEdited] = useState(false);
+
+  // Live data
+  const [worksheetData, setWorksheetData] = useState<Record<string, any[]>>({});
+  const [isLoadingData, setIsLoadingData] = useState(false);
+
+  const chatEndRef = useRef<HTMLDivElement>(null);
+  const inputRef = useRef<HTMLInputElement>(null);
+
+  // Auto-populate from worksheet query param
+  const worksheetId = (Array.isArray(router.query.worksheetId)
+    ? router.query.worksheetId[0]
+    : router.query.worksheetId) ?? null;
+
+  useEffect(() => {
+    if (worksheetId && messages.length === 0) {
+      const initialPrompt = `Create a custom report based on the "${worksheetId}" worksheet. Include all its columns.`;
+      handleSend(initialPrompt);
+    }
+  }, [worksheetId]); // eslint-disable-line react-hooks/exhaustive-deps
+
+  // Scroll to bottom on new messages
+  useEffect(() => {
+    chatEndRef.current?.scrollIntoView({ behavior: "smooth" });
+  }, [messages]);
+
+  // Fetch live data when definition changes
+  useEffect(() => {
+    if (definition) {
+      fetchLiveData(definition);
+    }
+  }, [definition]); // eslint-disable-line react-hooks/exhaustive-deps
+
+  const fetchLiveData = useCallback(
+    async (def: CustomReportDefinition) => {
+      const worksheetIds = new Set<string>();
+      worksheetIds.add(def.primary_worksheet_id);
+      for (const join of def.joins) {
+        worksheetIds.add(join.right_worksheet_id);
+      }
+
+      setIsLoadingData(true);
+      try {
+        const entries = await Promise.all(
+          [...worksheetIds].map(async (wsId) => {
+            const result = await post(`/v2/worksheets/${wsId}/query`, { selectors: {} }, orgMembership);
+            const rows = (Array.isArray(result) ? result : []).map((row: any) => row.data ?? row);
+            return [wsId, rows] as const;
+          }),
+        );
+        setWorksheetData(Object.fromEntries(entries));
+      } catch {
+        // Silently fail for live preview — data may not be available for all worksheets
+        setWorksheetData({});
+      } finally {
+        setIsLoadingData(false);
+      }
+    },
+    [orgMembership],
+  );
+
+  const handleSend = useCallback(
+    async (messageText?: string) => {
+      const text = messageText ?? input.trim();
+      if (!text) return;
+
+      const userMessage: ChatMessage = { role: "user", content: text };
+      setMessages((prev) => [...prev, userMessage]);
+      if (!messageText) setInput("");
+
+      setIsGenerating(true);
+      try {
+        // Build full conversation context for the LLM
+        const fullPrompt = [...messages, userMessage]
+          .filter((m) => m.role === "user")
+          .map((m) => m.content)
+          .join("\n\nUser refinement: ");
+
+        const result = await post("/v2/custom-reports/generate", { prompt: fullPrompt }, orgMembership);
+        const newDefinition = result as CustomReportDefinition;
+
+        setDefinition(newDefinition);
+        setMessages((prev) => [
+          ...prev,
+          {
+            role: "assistant",
+            content: `Generated report with ${newDefinition.columns.length} columns from ${new Set(newDefinition.columns.filter((c) => c.source).map((c) => c.source!.worksheet_id)).size} worksheet(s).`,
+            definition: newDefinition,
+          },
+        ]);
+      } catch (error: any) {
+        raiseError({
+          honeycombTraceparent: error.honeycombTraceparent,
+          message: error.message ?? i18next.format(t("common.something_went_wrong"), "capitalize"),
+          showInDialog: true,
+          status: error.status,
+          title: error.title ?? i18next.format(t("common.something_went_wrong"), "capitalize"),
+        });
+        setMessages((prev) => [
+          ...prev,
+          { role: "assistant", content: error.message ?? "Something went wrong. Please try again." },
+        ]);
+      } finally {
+        setIsGenerating(false);
+        inputRef.current?.focus();
+      }
+    },
+    [input, messages, orgMembership, raiseError, t],
+  );
+
+  const handleSave = useCallback(async () => {
+    if (!definition || !reportId.trim() || !reportTitle.trim()) return;
+    setIsSaving(true);
+    setShowSaveDialog(false);
+    try {
+      await post(
+        "/v2/custom-reports",
+        { report_id: reportId.trim(), title: reportTitle.trim(), user_prompt: messages.filter((m) => m.role === "user").map((m) => m.content).join("\n"), definition },
+        orgMembership,
+      );
+      setMainMenu(null); // Force menu refetch to show new report
+      const org = router.query.org;
+      await router.push(`/${org}/custom-report/${reportId.trim()}`);
+    } catch (error: any) {
+      raiseError({
+        honeycombTraceparent: error.honeycombTraceparent,
+        message: error.message ?? i18next.format(t("common.something_went_wrong"), "capitalize"),
+        showInDialog: true,
+        status: error.status,
+        title: error.title ?? i18next.format(t("common.something_went_wrong"), "capitalize"),
+      });
+    } finally {
+      setIsSaving(false);
+    }
+  }, [definition, reportId, reportTitle, messages, orgMembership, raiseError, router, t]);
+
+  const assembledRows = useMemo(() => {
+    if (!definition || Object.keys(worksheetData).length === 0) return [];
+    try {
+      return assembleCustomReport(definition, worksheetData);
+    } catch {
+      return [];
+    }
+  }, [definition, worksheetData]);
+
+  const columnDefs = useMemo(() => {
+    if (!definition) return [];
+    return buildColumnDefs(definition.columns, assembledRows, definition.default_grouping);
+  }, [definition, assembledRows]);
+
+  const handleKeyDown = useCallback(
+    (e: React.KeyboardEvent) => {
+      if (e.key === "Enter" && !e.shiftKey) {
+        e.preventDefault();
+        handleSend();
+      }
+    },
+    [handleSend],
+  );
+
+  return (
+    <div className="flex h-full">
+      {/* Left panel: Chat */}
+      <div className="flex w-[400px] min-w-[350px] flex-col border-r border-gray-200 dark:border-gray-700">
+        <div className="flex items-center justify-between border-b border-gray-200 p-3 dark:border-gray-700">
+          <span className="text-sm font-semibold">
+            {i18next.format(t("common._custom_report.new_custom_report"), "capitalize")}
+          </span>
+          {definition && (
+            <Tooltip title={i18next.format(t("common._custom_report.save_report"), "capitalize")}>
+              <IconButton
+                disabled={isSaving}
+                onClick={() => {
+                  setReportTitle("");
+                  setReportId("");
+                  setIdManuallyEdited(false);
+                  setShowSaveDialog(true);
+                }}
+                size="small"
+              >
+                {isSaving ? <LoaderCircle height={18} width={18} /> : <SaveOutlined fontSize="small" />}
+              </IconButton>
+            </Tooltip>
+          )}
+        </div>
+
+        {/* Messages */}
+        <div className="flex-1 overflow-y-auto p-3">
+          <div className="flex flex-col gap-3">
+            {messages.map((msg, i) => (
+              <div
+                key={i}
+                className={`rounded-lg px-3 py-2 text-sm ${
+                  msg.role === "user"
+                    ? "ml-8 self-end bg-blue-100 dark:bg-blue-900"
+                    : "mr-8 self-start bg-gray-100 dark:bg-gray-800"
+                }`}
+              >
+                {msg.content}
+                {msg.definition && (
+                  <div className="mt-1 text-xs text-gray-500">
+                    {msg.definition.columns.map((c) => c.title).join(" · ")}
+                  </div>
+                )}
+              </div>
+            ))}
+            {isGenerating && (
+              <div className="mr-8 flex items-center gap-2 self-start rounded-lg bg-gray-100 px-3 py-2 text-sm dark:bg-gray-800">
+                <LoaderCircle height={14} width={14} />
+                {i18next.format(t("common._custom_report.generating"), "capitalize")}
+              </div>
+            )}
+            <div ref={chatEndRef} />
+          </div>
+        </div>
+
+        {/* Input */}
+        <div className="border-t border-gray-200 p-3 dark:border-gray-700">
+          <div className="flex items-end gap-2">
+            <TextField
+              disabled={isGenerating}
+              fullWidth
+              inputRef={inputRef}
+              multiline
+              maxRows={4}
+              onChange={(e) => setInput(e.target.value)}
+              onKeyDown={handleKeyDown}
+              placeholder={
+                messages.length === 0
+                  ? t("common._custom_report.placeholder_initial")
+                  : t("common._custom_report.placeholder_refine")
+              }
+              size="small"
+              value={input}
+            />
+            <IconButton
+              color="primary"
+              disabled={!input.trim() || isGenerating}
+              onClick={() => handleSend()}
+              size="small"
+            >
+              {isGenerating ? <LoaderCircle height={20} width={20} /> : <SendOutlined />}
+            </IconButton>
+          </div>
+        </div>
+      </div>
+
+      {/* Right panel: Live report preview */}
+      <div className="flex flex-1 flex-col">
+        {definition ? (
+          <ReportGrid
+            columnDefs={columnDefs}
+            description={definition.description}
+            isLoading={isLoadingData}
+            rowData={assembledRows}
+            title={i18next.format(t("common._custom_report.preview"), "capitalize")}
+          />
+        ) : (
+          <div className="flex h-full items-center justify-center text-gray-400">
+            <div className="flex flex-col items-center gap-2">
+              <AutoAwesomeOutlined className="text-4xl" />
+              <span className="text-sm">{i18next.format(t("common._custom_report.describe_your_report"), "capitalize")}</span>
+            </div>
+          </div>
+        )}
+      </div>
+
+      {/* Save dialog */}
+      <Dialog open={showSaveDialog} onClose={() => setShowSaveDialog(false)}>
+        <DialogTitle>{i18next.format(t("common._custom_report.save_report"), "capitalize")}</DialogTitle>
+        <DialogContent className="flex flex-col gap-3 pt-2">
+          <TextField
+            autoFocus
+            fullWidth
+            label={i18next.format(t("common._custom_report.report_title"), "capitalize")}
+            onChange={(e) => {
+              setReportTitle(e.target.value);
+              if (!idManuallyEdited) {
+                setReportId(e.target.value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, ""));
+              }
+            }}
+            value={reportTitle}
+          />
+          <TextField
+            fullWidth
+            helperText={t("common._custom_report.report_id_helper")}
+            label={i18next.format(t("common._custom_report.report_id"), "capitalize")}
+            onChange={(e) => {
+              setReportId(e.target.value);
+              setIdManuallyEdited(true);
+            }}
+            value={reportId}
+          />
+        </DialogContent>
+        <DialogActions>
+          <Button onClick={() => setShowSaveDialog(false)}>{i18next.format(t("common.cancel"), "capitalize")}</Button>
+          <Button disabled={!reportId.trim() || !reportTitle.trim()} onClick={handleSave} variant="contained">
+            {i18next.format(t("common.save"), "capitalize")}
+          </Button>
+        </DialogActions>
+      </Dialog>
+    </div>
+  );
+}
