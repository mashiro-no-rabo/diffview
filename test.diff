+import { FileDownloadOutlined } from "@mui/icons-material";
+import { IconButton, Tooltip } from "@mui/material";
+import {
+  ColDef,
+  CsvExportModule,
+  GridReadyEvent,
+  ModuleRegistry,
+  TooltipModule,
+  ValidationModule,
+} from "ag-grid-community";
+import {
+  ColumnMenuModule,
+  ColumnsToolPanelModule,
+  ContextMenuModule,
+  ExcelExportModule,
+  RowGroupingModule,
+} from "ag-grid-enterprise";
+import { AgGridReact } from "ag-grid-react";
+import i18next from "i18next";
+import { type JSX, useCallback, useMemo, useRef } from "react";
+import { useTranslation } from "react-i18next";
+
+import { PageHeader } from "@plaio/components/ui";
+import { useLayoutStore } from "@plaio/data-access";
+import { getPlaioGridTheme } from "@plaio/util";
+
+ModuleRegistry.registerModules([
+  ColumnMenuModule,
+  ColumnsToolPanelModule,
+  ContextMenuModule,
+  CsvExportModule,
+  ExcelExportModule,
+  RowGroupingModule,
+  TooltipModule,
+  ValidationModule,
+]);
+
+export interface ReportGridProps {
+  columnDefs: ColDef[];
+  rowData: Record<string, any>[];
+  title: string;
+  description?: string;
+  isLoading?: boolean;
+}
+
+export function ReportGrid(props: Readonly<ReportGridProps>): JSX.Element {
+  const { t } = useTranslation();
+  const gridRef = useRef<AgGridReact>(null);
+  const theme = useLayoutStore((state) => state.layout.theme);
+
+  const plaioGridTheme = useMemo(() => {
+    return getPlaioGridTheme(theme);
+  }, [theme]);
+
+  const defaultColDef = useMemo<ColDef>(
+    () => ({
+      editable: false,
+      filter: true,
+      resizable: true,
+      sortable: true,
+    }),
+    [],
+  );
+
+  const onGridReady = useCallback((_event: GridReadyEvent) => {
+    gridRef.current?.api?.sizeColumnsToFit();
+  }, []);
+
+  const exportToExcel = useCallback(() => {
+    gridRef.current?.api?.exportDataAsExcel({
+      fileName: props.title,
+    });
+  }, [props.title]);
+
+  return (
+    <div className="flex h-full flex-col">
+      <PageHeader
+        title={props.title}
+        description={props.description}
+        showLoader={props.isLoading}
+        counter={props.rowData.length > 0 ? String(props.rowData.length) : undefined}
+      >
+        <Tooltip title={i18next.format(t("common._custom_report.export_to_excel"), "capitalize")}>
+          <IconButton size="small" onClick={exportToExcel}>
+            <FileDownloadOutlined fontSize="small" />
+          </IconButton>
+        </Tooltip>
+      </PageHeader>
+      <div className="flex-1">
+        <AgGridReact
+          ref={gridRef}
+          autoGroupColumnDef={{ minWidth: 200 }}
+          columnDefs={props.columnDefs}
+          defaultColDef={defaultColDef}
+          getRowId={(params) => params.data.id}
+          grandTotalRow="bottom"
+          groupDefaultExpanded={-1}
+          onGridReady={onGridReady}
+          overlayNoRowsTemplate={i18next.format(t("common.no_items_found"), "capitalize")}
+          rowData={props.rowData}
+          suppressAggFuncInHeader={true}
+          theme={plaioGridTheme}
+          tooltipShowDelay={1000}
+        />
+      </div>
+    </div>
+  );
+}
