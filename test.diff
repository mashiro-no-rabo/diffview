+]);
+
+export function ReportPage(): JSX.Element {
+  const { t } = useTranslation();
+  const router = useRouter();
+  const orgMembership = useOrgMembershipByPathParam();
+  const tokenFetcher = useTokenFetcher();
+  const raiseError = useLayoutStore((state) => state.raiseError);
+  const theme = useLayoutStore((state) => state.layout.theme);
+  const clientSideConfig = makeClientSideConfig();
+
+  const reportId = Array.isArray(router.query.id) ? router.query.id[0] : router.query.id;
+
+  const {
+    data: report,
+    isLoading: isLoadingReport,
+    mutate: mutateReport,
+  } = useSWR<CustomReport, AxiosError>(
+    reportId ? `${clientSideConfig.engineURL}/v2/custom-reports/${reportId}` : null,
+    tokenFetcher,
+  );
+
+  const [worksheetData, setWorksheetData] = useState<Record<string, any[]>>({});
+  const [isLoadingData, setIsLoadingData] = useState(false);
+  const [selectedTab, setSelectedTab] = useState(0);
+  const [isUpdating, setIsUpdating] = useState(false);
+  const [updatePrompt, setUpdatePrompt] = useState("");
+  const [showUpdateInput, setShowUpdateInput] = useState(false);
+
+  const gridRef = useRef<AgGridReact>(null);
+  const updateInputRef = useRef<HTMLInputElement>(null);
+  const plaioGridTheme = useMemo(() => getPlaioGridTheme(theme), [theme]);
+
+  // Build synthetic worksheet structure for filter/toolbox compatibility
+  const worksheet = useMemo(() => {
+    if (!report?.definition || !reportId) return null;
+    return toWorksheetStructure(reportId, report.title, report.definition);
+  }, [report?.definition, reportId]);
+
+  const worksheetId = reportId ?? "";
+  const userFilters = useWorksheetStore((state) => state.worksheets?.[worksheetId]?.userFilters) ?? [];
+
+  const fetchWorksheetData = useCallback(async () => {
+    if (!report?.definition) return;
+
+    const wsIds = new Set<string>();
+    wsIds.add(report.definition.primary_worksheet_id);
+    for (const join of report.definition.joins) {
+      wsIds.add(join.right_worksheet_id);
+    }
+
+    setIsLoadingData(true);
+    try {
+      const entries = await Promise.all(
+        [...wsIds].map(async (wsId) => {
+          const result = await post(`/v2/worksheets/${wsId}/query`, { selectors: {} }, orgMembership);
+          const rows = (Array.isArray(result) ? result : []).map((row: any) => row.data ?? row);
+          return [wsId, rows] as const;
+        }),
+      );
+      setWorksheetData(Object.fromEntries(entries));
+    } catch (error: any) {
+      raiseError({
+        honeycombTraceparent: error.honeycombTraceparent,
+        message: error.message ?? i18next.format(t("common.something_went_wrong"), "capitalize"),
+        showInDialog: false,
+        status: error.status,
+        title: error.title ?? i18next.format(t("common.something_went_wrong"), "capitalize"),
+      });
+    } finally {
+      setIsLoadingData(false);
+    }
+  }, [report, orgMembership, raiseError, t]);
+
+  useEffect(() => {
+    if (report?.definition) {
+      fetchWorksheetData();
+    }
+  }, [report?.definition]); // eslint-disable-line react-hooks/exhaustive-deps
+
+  const assembledRows = useMemo(() => {
+    if (!report?.definition || Object.keys(worksheetData).length === 0) return [];
+    try {
+      return assembleCustomReport(report.definition, worksheetData);
+    } catch {
+      return [];
+    }
+  }, [report?.definition, worksheetData]);
+
+  // Apply user filters (client-side text/list filtering)
+  const filteredRows = useMemo(() => {
+    if (userFilters.length === 0) return assembledRows;
+    return assembledRows.filter((row) =>
+      userFilters.every((f) => {
+        const value = row[f.columnName];
+        if (f.text) {
+          return value != null && String(value).toLowerCase().includes(f.text.toLowerCase());
+        }
+        if (f.list && f.list.length > 0) {
+          return f.list.map((v) => String(v).toLowerCase()).includes(String(value ?? "").toLowerCase());
+        }
+        return true;
+      }),
+    );
+  }, [assembledRows, userFilters]);
+
+  const columnDefs = useMemo(() => {
+    if (!report?.definition) return [];
+    return buildColumnDefs(report.definition.columns, assembledRows, report.definition.default_grouping);
+  }, [report?.definition, assembledRows]);
+
+  const defaultColDef = useMemo<ColDef>(
+    () => ({
+      editable: false,
+      filter: true,
+      resizable: true,
+      sortable: true,
+    }),
+    [],
+  );
+
+  const onGridReady = useCallback((_event: GridReadyEvent) => {
+    gridRef.current?.api?.sizeColumnsToFit();
+  }, []);
+
+  const exportExcel = useCallback(() => {
+    gridRef.current?.api?.exportDataAsExcel({ fileName: report?.title ?? "report" });
+  }, [report]);
+
+  const handleUpdateReport = useCallback(async () => {
+    if (!updatePrompt.trim() || !report?.definition || !reportId) return;
+    setIsUpdating(true);
+    try {
+      const result = await post(
+        `/v2/custom-reports/${reportId}/update`,
+        { prompt: updatePrompt, current_definition: report.definition },
+        orgMembership,
+      );
+      setUpdatePrompt("");
+      setShowUpdateInput(false);
+      mutateReport(); // Refetch report
+    } catch (error: any) {
+      raiseError({
+        honeycombTraceparent: error.honeycombTraceparent,
+        message: error.message ?? i18next.format(t("common.something_went_wrong"), "capitalize"),
+        showInDialog: true,
+        status: error.status,
+        title: error.title ?? i18next.format(t("common.something_went_wrong"), "capitalize"),
+      });
+    } finally {
+      setIsUpdating(false);
+    }
+  }, [updatePrompt, report, reportId, orgMembership, raiseError, mutateReport, t]);
+
+  // Toolbox items
+  const toolboxItems: ToolboxItem[] = useMemo(
+    () => [
+      {
+        id: "update-report",
+        type: ToolboxItemTypeEnum.Button,
+        icon: <AutoAwesomeOutlined className={toolboxIconClass} />,
+        title: i18next.format(t("common._custom_report.update_report"), "capitalize"),
+        onClick: () => {
+          setShowUpdateInput(true);
+          setTimeout(() => updateInputRef.current?.focus(), 100);
+        },
+      },
+      { id: "action-divider", type: ToolboxItemTypeEnum.Divider },
+      {
+        id: "refresh-data",
+        type: ToolboxItemTypeEnum.Button,
+        icon: <RefreshOutlined className={toolboxIconClass} />,
+        title: i18next.format(t("worksheet._grid_toolbox.refresh_data"), "capitalize"),
+        onClick: fetchWorksheetData,
+      },
+      {
+        id: "export-excel",
+        type: ToolboxItemTypeEnum.Button,
+        icon: <FileDownloadOutlined className={toolboxIconClass} />,
+        title: i18next.format(t("worksheet._grid_toolbox.export_excel"), "capitalize"),
+        onClick: exportExcel,
+      },
+    ],
+    [t, fetchWorksheetData, exportExcel],
+  );
+
+  if (isLoadingReport) {
+    return (
+      <div className="flex h-full items-center justify-center">
+        <LoaderCircle height={48} width={48} />
+      </div>
+    );
+  }
+
+  if (!report || !worksheet) {
+    return (
+      <div className="flex h-full items-center justify-center">
+        <span>{i18next.format(t("common.page_not_found"), "capitalize")}</span>
+      </div>
+    );
+  }
+
+  return (
+    <div className="flex h-full flex-col py-2">
+      <PageHeader
+        counter={filteredRows.length > 0 ? String(filteredRows.length) : undefined}
+        description={report.definition.description ?? undefined}
+        showLoader={isLoadingData || isUpdating}
+        title={report.title}
+      >
+        <div className="flex w-full items-center gap-2">
+          <div className="grow" />
+          <div className="flex flex-row items-center gap-2">
+            {selectedTab === 0 && (
+              <div className="-mr-2">
+                <WorksheetFilterButton
+                  columns={worksheet.columns}
+                  onToggleFilterRow={() => {}}
+                  rowsData={assembledRows as Record<string, GridValue>[]}
+                  showFilterRow={false}
+                  userFilters={userFilters}
+                  worksheetId={worksheetId}
+                />
+              </div>
+            )}
+            <Toolbox
+              inline
+              items={toolboxItems}
+              showDot={false}
+              showSparkles={false}
+              title={i18next.format(t("common.more"), "capitalize")}
+            />
+          </div>
+        </div>
+      </PageHeader>
+
+      {/* Update report input bar */}
+      {showUpdateInput && (
+        <div className="flex items-center gap-2 border-b border-gray-200 px-4 py-2 dark:border-gray-700">
+          <TextField
+            autoFocus
+            disabled={isUpdating}
+            fullWidth
+            inputRef={updateInputRef}
+            onKeyDown={(e) => {
+              if (e.key === "Enter" && !e.shiftKey) {
+                e.preventDefault();
+                handleUpdateReport();
+              }
+              if (e.key === "Escape") {
+                setShowUpdateInput(false);
+                setUpdatePrompt("");
+              }
+            }}
+            onChange={(e) => setUpdatePrompt(e.target.value)}
+            placeholder={t("common._custom_report.placeholder_refine")}
+            size="small"
+            value={updatePrompt}
+          />
+          {isUpdating && <LoaderCircle height={20} width={20} />}
+        </div>
+      )}
+
+      {/* Tabs */}
+      <Box component="nav" className="flex w-full items-center pr-2">
+        <Tabs onChange={(_, v) => setSelectedTab(v)} value={selectedTab}>
+          <Tab
+            {...A11yTab({ name: "grid", prefix: "custom-report" })}
+            label={
+              <WorksheetTab
+                counter={null}
+                hasError={false}
+                icon={<MenuOutlined />}
+                isLoading={isLoadingData}
+                label={i18next.format(t("worksheet.grid"), "capitalize")}
+              />
+            }
+            value={0}
+          />
+          <Tab
+            {...A11yTab({ name: "tasks", prefix: "custom-report" })}
+            label={
+              <WorksheetTab
+                counter={0}
+                hasError={false}
+                icon={<CheckCircleOutlineOutlined />}
+                isLoading={false}
+                label={i18next.format(t("task.tasks"), "capitalize")}
+              />
+            }
+            value={1}
+          />
+        </Tabs>
+      </Box>
+
+      {/* Grid tab */}
+      {selectedTab === 0 && (
+        <div className="flex-1">
+          <AgGridReact
+            ref={gridRef}
+            autoGroupColumnDef={{ minWidth: 200 }}
+            columnDefs={columnDefs}
+            defaultColDef={defaultColDef}
+            getRowId={(params: GetRowIdParams) => params.data.id}
+            grandTotalRow="bottom"
+            groupDefaultExpanded={-1}
+            onGridReady={onGridReady}
+            overlayNoRowsTemplate={i18next.format(t("common.no_items_found"), "capitalize")}
+            rowData={filteredRows}
+            suppressAggFuncInHeader={true}
+            theme={plaioGridTheme}
+            tooltipShowDelay={1000}
+          />
+        </div>
+      )}
+
+      {/* Tasks tab — placeholder for now */}
+      {selectedTab === 1 && (
+        <div className="flex h-full items-center justify-center text-gray-400">
+          <span>{i18next.format(t("worksheet.tasks"), "capitalize")}</span>
+        </div>
+      )}
+    </div>
+  );
+}
