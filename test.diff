@@ -0,0 +1,49 @@
+from __future__ import annotations
+
+from typing import Literal
+
+from pydantic import BaseModel
+
+from app.frameworks.data import DataType, TimeSeriesFormat
+from app.frameworks.worksheet import ColumnAggregator, ColumnWidth
+
+
+class ColumnSource(BaseModel):
+    worksheet_id: str
+    column_id: str
+
+
+class ComputedExpression(BaseModel):
+    expression: str
+
+
+class ReportColumnDefinition(BaseModel):
+    id: str
+    title: str
+    description: str = ""
+    source: ColumnSource | None = None
+    computed: ComputedExpression | None = None
+    data_type: DataType
+    aggregator: ColumnAggregator | None = None
+    width: ColumnWidth = ColumnWidth.MEDIUM
+    postfix: str | None = None
+    default_visible: bool = True
+    default_ui_filterable: bool = False
+    is_ui_filter_dropdown: bool = False
+    time_series_format: TimeSeriesFormat | None = None
+
+
+class JoinSpec(BaseModel):
+    left_worksheet_id: str
+    right_worksheet_id: str
+    left_key: str | list[str]
+    right_key: str | list[str]
+    join_type: Literal["inner", "left"] = "left"
+
+
+class CustomReportDefinition(BaseModel):
+    description: str
+    primary_worksheet_id: str
+    columns: list[ReportColumnDefinition]
+    joins: list[JoinSpec]
+    default_grouping: list[str] = []
