@@ -0,0 +1,96 @@
+from pydantic import BaseModel
+
+
+class JoinPath(BaseModel):
+    left_worksheet_id: str
+    right_worksheet_id: str
+    shared_keys: list[str]
+    description: str
+
+
+KNOWN_JOINS: list[JoinPath] = [
+    # Demand-domain joins (shared: item_reference, demand_segment_reference, location_name)
+    JoinPath(
+        left_worksheet_id="actual-sales",
+        right_worksheet_id="demand",
+        shared_keys=["item_reference", "demand_segment_reference", "location_name"],
+        description="Actual sales to demand planning rows",
+    ),
+    JoinPath(
+        left_worksheet_id="actual-sales",
+        right_worksheet_id="forecast-accuracy",
+        shared_keys=["item_reference", "demand_segment_reference", "location_name"],
+        description="Actual sales to forecast accuracy metrics",
+    ),
+    JoinPath(
+        left_worksheet_id="demand",
+        right_worksheet_id="forecast-accuracy",
+        shared_keys=["item_reference", "demand_segment_reference", "location_name"],
+        description="Demand planning to forecast accuracy metrics",
+    ),
+    JoinPath(
+        left_worksheet_id="demand",
+        right_worksheet_id="customer-orders",
+        shared_keys=["item_reference", "demand_segment_reference", "location_name"],
+        description="Demand planning to customer orders",
+    ),
+    JoinPath(
+        left_worksheet_id="actual-sales",
+        right_worksheet_id="customer-orders",
+        shared_keys=["item_reference", "demand_segment_reference", "location_name"],
+        description="Actual sales to customer orders",
+    ),
+    # Supply-domain joins (shared: item_reference, location_name)
+    JoinPath(
+        left_worksheet_id="supply-overview",
+        right_worksheet_id="supply-planning",
+        shared_keys=["item_reference", "location_name"],
+        description="Supply overview to supply planning details",
+    ),
+    JoinPath(
+        left_worksheet_id="supply-overview",
+        right_worksheet_id="supply-orders",
+        shared_keys=["item_reference", "location_name"],
+        description="Supply overview to supply orders",
+    ),
+    JoinPath(
+        left_worksheet_id="supply-planning",
+        right_worksheet_id="supply-orders",
+        shared_keys=["item_reference", "location_name"],
+        description="Supply planning to supply orders",
+    ),
+    # Cross-domain: demand ↔ supply (shared: item_reference, location_name)
+    JoinPath(
+        left_worksheet_id="demand",
+        right_worksheet_id="supply-overview",
+        shared_keys=["item_reference", "location_name"],
+        description="Demand planning to supply overview (cross-domain)",
+    ),
+    JoinPath(
+        left_worksheet_id="actual-sales",
+        right_worksheet_id="supply-overview",
+        shared_keys=["item_reference", "location_name"],
+        description="Actual sales to supply overview (cross-domain)",
+    ),
+    # Production links
+    JoinPath(
+        left_worksheet_id="production",
+        right_worksheet_id="demand",
+        shared_keys=["item_reference"],
+        description="Production to demand planning via item",
+    ),
+    JoinPath(
+        left_worksheet_id="production",
+        right_worksheet_id="supply-overview",
+        shared_keys=["item_reference"],
+        description="Production to supply overview via item",
+    ),
+]
+
+
+def format_join_knowledge() -> str:
+    lines = ["## Known Join Paths Between Worksheets", ""]
+    for jp in KNOWN_JOINS:
+        keys = ", ".join(jp.shared_keys)
+        lines.append(f"- {jp.left_worksheet_id} ↔ {jp.right_worksheet_id}: join on [{keys}] — {jp.description}")
+    return "\n".join(lines)
