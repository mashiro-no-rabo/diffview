+from fastapi import APIRouter
+from pydantic import BaseModel
+
+from app.core.deps import AsyncCustomerDbDep, CustomAttributesDep, UserDep
+from app.custom_reports import service
+from app.custom_reports.schemas import CustomReportDefinition
+
+router = APIRouter(tags=["Custom Reports"])
+
+
+class GenerateReportRequest(BaseModel):
+    prompt: str
+
+
+class CreateReportRequest(BaseModel):
+    report_id: str
+    title: str
+    user_prompt: str
+    definition: CustomReportDefinition
+
+
+class UpdateReportRequest(BaseModel):
+    prompt: str
+    current_definition: CustomReportDefinition
+
+
+@router.post("/generate")
+async def generate_report(body: GenerateReportRequest, user: UserDep, _: CustomAttributesDep) -> CustomReportDefinition:
+    return await service.generate_report(body.prompt)
+
+
+@router.post("/")
+async def create_report(body: CreateReportRequest, db_session: AsyncCustomerDbDep, user: UserDep, _: CustomAttributesDep):
+    return await service.create_report(
+        db_session,
+        report_id=body.report_id,
+        title=body.title,
+        user_prompt=body.user_prompt,
+        definition=body.definition,
+    )
+
+
+@router.get("/")
+async def list_reports(db_session: AsyncCustomerDbDep, user: UserDep, _: CustomAttributesDep):
+    return await service.list_reports(db_session)
+
+
+@router.get("/{report_id}")
+async def get_report(report_id: str, db_session: AsyncCustomerDbDep, user: UserDep, _: CustomAttributesDep):
+    return await service.get_report(db_session, report_id)
+
+
+@router.post("/{report_id}/update")
+async def update_report_with_llm(
+    report_id: str, body: UpdateReportRequest, db_session: AsyncCustomerDbDep, user: UserDep, _: CustomAttributesDep
+) -> CustomReportDefinition:
+    return await service.update_report(db_session, report_id, body.prompt, body.current_definition)
+
+
+@router.delete("/{report_id}", status_code=204)
+async def delete_report(report_id: str, db_session: AsyncCustomerDbDep, user: UserDep, _: CustomAttributesDep) -> None:
+    await service.delete_report(db_session, report_id)
