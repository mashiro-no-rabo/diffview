@@ -0,0 +1,124 @@
+from pydantic_ai import Agent
+from pydantic_ai.models.bedrock import BedrockConverseModel
+from pydantic_ai.providers.bedrock import BedrockProvider
+
+from app.custom_reports.join_knowledge import format_join_knowledge
+from app.custom_reports.schemas import CustomReportDefinition
+from app.frameworks.worksheet import ColumnAggregator
+from app.frameworks.worksheet._runtime.column import generate_columns  # ast-grep-ignore: worksheet-import
+from app.frameworks.worksheet._runtime.registry import WorksheetRegistry  # ast-grep-ignore: worksheet-import
+from app.settings import settings
+
+Agent.instrument_all()
+
+_bedrock_provider = BedrockProvider(
+    region_name=settings.aws_region,
+    aws_access_key_id=settings.integration_s3_access_key.get_secret_value(),
+    aws_secret_access_key=settings.integration_s3_secret_key.get_secret_value(),
+)
+
+
+def build_system_prompt() -> str:
+    import app._worksheets  # noqa: F401 — ensure worksheets are registered
+
+    sections: list[str] = [
+        "You are a custom report builder for a supply chain planning platform.",
+        "You create report definitions that combine data from multiple worksheets.",
+        "",
+        "# Available Worksheets and Their Columns",
+        "",
+    ]
+
+    worksheet_map = WorksheetRegistry._get_worksheet_map()
+    for ws_id, ws_cls in sorted(worksheet_map.items()):
+        if ws_id == "forecast-ytd-ytg":
+            continue
+
+        columns = generate_columns(ws_cls)
+        sections.append(f"## Worksheet: {ws_id} — {ws_cls.title}")
+        sections.append(f"Description: {ws_cls.description}")
+        sections.append("Columns:")
+        for col in columns:
+            extras = []
+            if col.aggregator:
+                extras.append(f"aggregator={col.aggregator}")
+            if col.time_series_format:
+                extras.append(f"time_series_format={col.time_series_format}")
+            extras_str = ", " + ", ".join(extras) if extras else ""
+            sections.append(f"  - {col.id}: {col.title} (data_type={col.data_type}{extras_str})")
+            if col.description:
+                sections.append(f"    Description: {col.description}")
+        sections.append("")
+
+    sections.append(format_join_knowledge())
+    sections.append("")
+    sections.append("# AG Grid Aggregation Options")
+    sections.append("Available aggregators: " + ", ".join(a.value for a in ColumnAggregator))
+    sections.append("")
+    sections.append("# Instructions")
+    sections.append("- Choose a primary_worksheet_id as the main data source (the worksheet whose rows form the base)")
+    sections.append("- Use the exact column IDs and worksheet IDs from the lists above")
+    sections.append("- Set appropriate data_type, aggregator, and width for each column")
+    sections.append("- Mark dimension/grouping columns as default_ui_filterable=True and is_ui_filter_dropdown=True")
+    sections.append("- Use computed expressions for calculated fields (e.g. 'column_a - column_b')")
+    sections.append("")
+    sections.append("# CRITICAL: TimeSeries Columns")
+    sections.append("- Columns listed above with time_series_format (e.g. YEAR_MONTH) are TimeSeries columns")
+    sections.append("- TimeSeries columns contain a dict of {date: value} pairs, expanded into columns per date")
+    sections.append("- When including a TimeSeries source column in your report:")
+    sections.append("  - Keep the SAME data_type as the source (usually INTEGER or DECIMAL)")
+    sections.append("  - MUST set time_series_format to the EXACT same value as the source column")
+    sections.append("  - The frontend expands it into separate date columns automatically")
+    sections.append("- Example: if source has forecast_values (data_type=INTEGER, time_series_format=YEAR_MONTH)")
+    sections.append('  your column MUST have data_type="INTEGER" and time_series_format="YEAR_MONTH"')
+    sections.append("- If time_series_format is null, the column renders as a single value — NOT expanded")
+    sections.append("")
+    sections.append("# CRITICAL: Join Specs")
+    sections.append("- When columns come from MORE THAN ONE worksheet, you MUST add a JoinSpec for each pair")
+    sections.append("- The left_worksheet_id in a JoinSpec should be the primary_worksheet_id")
+    sections.append("- The right_worksheet_id is the secondary worksheet being joined")
+    sections.append("- left_key and right_key must be column IDs that exist on the respective worksheets")
+    sections.append("- Use the Known Join Paths above to determine which keys to join on")
+    sections.append("- If all columns come from a single worksheet, joins can be empty")
+    sections.append("- NEVER reference columns from a worksheet without a join to it")
+
+    return "\n".join(sections)
+
+
+# generation_agent = Agent(
+#     BedrockConverseModel(
+#         model_name="eu.amazon.nova-pro-v1:0",
+#         provider=_bedrock_provider,
+#     ),
+#     output_type=CustomReportDefinition,
+#     retries=3,
+# )
+
+generation_agent = Agent(
+    BedrockConverseModel(
+        model_name="eu.anthropic.claude-haiku-4-5-20251001-v1:0",
+        provider=_bedrock_provider,
+    ),
+    output_type=CustomReportDefinition,
+    retries=3,
+)
+
+
+@generation_agent.system_prompt
+def _generation_system_prompt() -> str:
+    return build_system_prompt()
+
+
+validation_agent = Agent(
+    BedrockConverseModel(
+        model_name="eu.anthropic.claude-3-5-haiku-20241022-v1:0",
+        provider=_bedrock_provider,
+    ),
+    output_type=CustomReportDefinition,
+    system_prompt=(
+        "You are a report definition validator. Given a custom report definition and the user's original prompt, "
+        "verify the definition is correct and complete. Fix any issues with column references, join specs, "
+        "or data types. Return the corrected definition."
+    ),
+    retries=2,
+)
