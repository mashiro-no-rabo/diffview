+from __future__ import annotations
+
+import pytest
+
+from app.custom_reports.agent import build_system_prompt, generation_agent
+from app.custom_reports.schemas import CustomReportDefinition
+from app.frameworks.worksheet._runtime.column import generate_columns  # ast-grep-ignore: worksheet-import
+from app.frameworks.worksheet._runtime.registry import WorksheetRegistry  # ast-grep-ignore: worksheet-import
+
+FORECAST_YTD_YTG_PROMPT = (
+    "Create a 12-month rolling forecast report for the current calendar year. "
+    "Show item reference, item name, demand segment reference, and location as identity columns. "
+    "Include a monthly rolling forecast time series. "
+    "Add budget total, variance vs budget, and percentage vs budget columns. "
+    "Add last year total sales, variance vs last year, and percentage vs last year columns. "
+    "Include YTD (year-to-date) and YTG (year-to-go) columns. "
+    "Add average columns: YTD average, budget average, rolling forecast current month average, and last year average. "
+    "Use the demand and actual-sales worksheets as sources."
+)
+
+EXPECTED_IDENTITY_COLUMNS = {"item_reference", "item_name", "demand_segment_reference", "location_name"}
+
+EXPECTED_METRIC_COLUMNS = {
+    "budget_total",
+    "vs_budget",
+    "percentage_budget",
+    "ly_total_sales",
+    "ly_vs_sales",
+    "ly_percentage_sales",
+    "ytd",
+    "ytg",
+}
+
+
+@pytest.mark.skip(reason="Requires AWS Bedrock credentials")
+async def test_generate_forecast_ytd_ytg_definition():
+    result = await generation_agent.run(FORECAST_YTD_YTG_PROMPT)
+    definition: CustomReportDefinition = result.output
+
+    assert definition.title, "Definition should have a title"
+    assert definition.description, "Definition should have a description"
+    assert definition.primary_worksheet_id in ("actual-sales", "demand"), (
+        f"Primary worksheet should be actual-sales or demand, got {definition.primary_worksheet_id}"
+    )
+
+    column_ids = {col.id for col in definition.columns}
+
+    # Check identity columns
+    missing_identity = EXPECTED_IDENTITY_COLUMNS - column_ids
+    assert not missing_identity, f"Missing identity columns: {missing_identity}"
+
+    # Check that at least some metric columns are present
+    found_metrics = EXPECTED_METRIC_COLUMNS & column_ids
+    assert len(found_metrics) >= 4, (
+        f"Expected at least 4 metric columns, found {len(found_metrics)}: {found_metrics}"
+    )
+
+    # Check that we have at least one time series column
+    ts_columns = [col for col in definition.columns if col.time_series_format is not None]
+    assert len(ts_columns) >= 1, "Expected at least one time series column for rolling forecast"
+
+    # All source columns must reference valid worksheets
+    import app._worksheets  # noqa: F401
+
+    worksheet_map = WorksheetRegistry._get_worksheet_map()
+    for col in definition.columns:
+        if col.source:
+            assert col.source.worksheet_id in worksheet_map, (
+                f"Column {col.id} references unknown worksheet {col.source.worksheet_id}"
+            )
+
+    # Check joins exist if multiple worksheets are used
+    source_worksheets = {col.source.worksheet_id for col in definition.columns if col.source}
+    if len(source_worksheets) > 1:
+        assert len(definition.joins) >= 1, "Multiple source worksheets require at least one join"
+
+    print("\n--- Generated Definition ---")
+    print(f"Title: {definition.title}")
+    print(f"Primary: {definition.primary_worksheet_id}")
+    print(f"Columns ({len(definition.columns)}):")
+    for col in definition.columns:
+        src = f"  source={col.source.worksheet_id}.{col.source.column_id}" if col.source else ""
+        comp = f"  computed={col.computed.expression}" if col.computed else ""
+        print(f"  - {col.id}: {col.title} ({col.data_type}){src}{comp}")
+    print(f"Joins ({len(definition.joins)}):")
+    for join in definition.joins:
+        print(f"  - {join.left_worksheet_id} ↔ {join.right_worksheet_id} on {join.left_key}")
+
+
+@pytest.mark.skip(reason="Requires AWS Bedrock credentials")
+async def test_compare_with_static_worksheet():
+    import app._worksheets  # noqa: F401
+
+    # Get static forecast-ytd-ytg columns
+    static_ws = WorksheetRegistry.get_worksheet_by_id("forecast-ytd-ytg")
+    static_columns = generate_columns(static_ws)
+    static_col_ids = {col.id for col in static_columns}
+
+    # Generate definition
+    result = await generation_agent.run(FORECAST_YTD_YTG_PROMPT)
+    definition: CustomReportDefinition = result.output
+    generated_col_ids = {col.id for col in definition.columns}
+
+    # Report comparison
+    matched = static_col_ids & generated_col_ids
+    missing_from_generated = static_col_ids - generated_col_ids
+    extra_in_generated = generated_col_ids - static_col_ids
+
+    print("\n--- Column Comparison ---")
+    print(f"Static columns: {len(static_col_ids)}")
+    print(f"Generated columns: {len(generated_col_ids)}")
+    print(f"Matched: {len(matched)} — {sorted(matched)}")
+    print(f"Missing from generated: {sorted(missing_from_generated)}")
+    print(f"Extra in generated: {sorted(extra_in_generated)}")
+
+    # We expect at least 50% column match
+    match_ratio = len(matched) / len(static_col_ids) if static_col_ids else 0
+    assert match_ratio >= 0.5, (
+        f"Expected at least 50% column match, got {match_ratio:.0%}. "
+        f"Missing: {sorted(missing_from_generated)}"
+    )
+
+
+@pytest.mark.skip(reason="Requires AWS Bedrock credentials")
+async def test_system_prompt_is_valid():
+    prompt = build_system_prompt()
+    assert "Available Worksheets" in prompt
+    assert "Known Join Paths" in prompt
+    assert "forecast-ytd-ytg" not in prompt, "forecast-ytd-ytg should be excluded from available worksheets"
+    assert "actual-sales" in prompt
+    assert "demand" in prompt
diff --git a/next/components/custom-reports/report-builder.tsx b/next/components/custom-reports/report-builder.tsx
